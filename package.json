{
  "name": "botc-grimoire",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Personal Blood on the Clocktower digital grimoire — local host, phones join via browser",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "fetch-roles": "node scripts/fetch-roles.mjs",
    "dev": "concurrently -n server,client -c blue,magenta \"node --watch server/index.mjs\" \"vite\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.mjs",
    "serve": "npm run build && npm run start"
  },
  "dependencies": {
    "express": "^4.21.2",
    "nanoid": "^5.0.9",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
